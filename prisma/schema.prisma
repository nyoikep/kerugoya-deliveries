generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id                    String             @id @default(cuid())
  email                 String             @unique
  phone                 String?            @unique
  idNumber              String?            @unique
  idCardUrl             String?
  numberPlate           String?            @unique
  motorcyclePlateNumber String?            @unique
  password              String
  name                  String?
  role                  String             @default("CLIENT")
  status                String             @default("APPROVED")
  loyaltyPoints         Int                @default(0)
  isGold                Boolean            @default(false)
  fcmToken              String?
  resetToken            String?
  resetTokenExpiry      DateTime?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  ownedBusinesses       Business[]
  deliveriesAsRider     DeliveryRequest[]  @relation("RiderDeliveries")
  deliveriesAsClient    DeliveryRequest[]  @relation("ClientDeliveries")
  mpesaTransactions     MpesaTransaction[]
  ratingsAsClient       Rating[]           @relation("ClientRatings")
  ratingsAsRider        Rating[]           @relation("RiderRatings")

  @@map("User")
}

model DeliveryRequest {
  id               String            @id @default(cuid())
  description      String?
  clientLocation   String
  destination      String
  status           String            @default("PENDING")
  price            Float             @default(0)
  platformFee      Float             @default(0)
  isExpress        Boolean           @default(false)
  tipAmount        Float             @default(0)
  surgeMultiplier  Float             @default(1.0)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  clientId         String
  riderId          String?
  scheduledAt      DateTime?
  cartItems        CartItem[]
  rider            User?             @relation("RiderDeliveries", fields: [riderId], references: [id])
  client           User              @relation("ClientDeliveries", fields: [clientId], references: [id])
  mpesaTransaction MpesaTransaction?

  @@index([status])
  @@index([clientId])
  @@index([riderId])
}

model Product {
  id          String     @id @default(cuid())
  name        String     @unique
  description String?
  price       Float
  businessId  String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  imageUrl    String?
  cartItems   CartItem[]
  business    Business   @relation(fields: [businessId], references: [id])

  @@index([businessId])
}

model CartItem {
  id                String           @id @default(cuid())
  productId         String
  quantity          Int
  deliveryRequestId String?
  deliveryRequest   DeliveryRequest? @relation(fields: [deliveryRequestId], references: [id])
  product           Product          @relation(fields: [productId], references: [id])
}

model Business {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?
  category    String    @default("SHOP")
  isFeatured  Boolean   @default(false)
  ownerId     String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  owner       User      @relation(fields: [ownerId], references: [id])
  products    Product[]
}

model Rating {
  id        String   @id @default(cuid())
  rating    Int
  comment   String?
  riderId   String
  clientId  String
  createdAt DateTime @default(now())
  client    User     @relation("ClientRatings", fields: [clientId], references: [id])
  rider     User     @relation("RiderRatings", fields: [riderId], references: [id])
}

model MpesaTransaction {
  id                 String           @id @default(cuid())
  merchantRequestID  String
  checkoutRequestID  String           @unique
  resultCode         String
  resultDesc         String?
  mpesaReceiptNumber String?          @unique
  amount             Float
  transactionDate    String
  phoneNumber        String
  status             String           @default("PENDING")
  userId             String
  deliveryRequestId  String?          @unique
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  deliveryRequest    DeliveryRequest? @relation(fields: [deliveryRequestId], references: [id])
  user               User             @relation(fields: [userId], references: [id])

  @@index([userId])
}
